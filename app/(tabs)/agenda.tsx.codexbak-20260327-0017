        overshootRight={false}
        rightThreshold={32}
      >
        {card}
      </Swipeable>
    );
  };

  const renderAgendaDaySection = (item: AgendaDaySection, compactCards = false) => {
    const expanded = giornoEspanso === item.date;

    return (
      <View
        key={`section-${item.date}`}
        style={[
